{
  "name": "launchgate-server",
  "version": "1.0.0",
  "description": "LaunchGate MCP Server — Supabase 兼容",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "db:push": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "lint": "eslint src/",
    "test": "npx vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@prisma/client": "^5.17.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "resend": "^3.5.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}