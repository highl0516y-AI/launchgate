# Cloudflare Workers MCP
name = "launchgate-wrangler"
main = "src/worker-complete.ts"
compatibility_date = "2025-12-18"

account_id = ""

[vars]
QQ_APP_ID = ""
NEXT_PUBLIC_APP_URL = "https://launchgate.ai"
WECHAT_APP_ID = ""

[[d1_databases]]
binding = "LAUNCHGATE_DB"
database_name = "launchgate-db"
database_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

[[kv_namespaces]]
binding = "LAUNCHGATE_KV"
id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"